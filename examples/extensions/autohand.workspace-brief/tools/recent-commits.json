{
  "name": "brief_recent_commits",
  "description": "Show a bounded number of recent commits for a project briefing",
  "parameters": {
    "type": "object",
    "properties": {
      "count": {
        "type": "number",
        "description": "Maximum number of recent commits"
      }
    },
    "required": [
      "count"
    ]
  },
  "handler": "git log --max-count={{count}} --oneline",
  "source": "user"
}
